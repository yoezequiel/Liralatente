---
import Layout from "../../Layouts/Layout.astro";
import PoesiaCard from "../../components/PoetryCard.astro";
import { getCollection } from "astro:content";
import { getAllCategories } from "../../data/categories";

export async function getStaticPaths() {
    return getAllCategories().map((categoria) => ({
        params: { categoria: categoria.slug },
        props: { categoria },
    }));
}

const { categoria } = Astro.props;

const all = await getCollection("poesias");
const filtered = all
    .filter(
        (p) => p.data.categorias && p.data.categorias.includes(categoria.slug),
    )
    .sort((a, b) => b.data.index - a.data.index);
---

<Layout title={`${categoria.name} • Categoría`} description={`Obras en la categoría ${categoria.name}: ${categoria.description}`}>
    <div class="category-hero" style={`--cat: ${categoria.color}`}>
        <div class="cat-icon" aria-hidden="true">{categoria.icon}</div>
        <h1 class="cat-title">{categoria.name}</h1>
        <p class="cat-desc">{categoria.description}</p>
        <div class="cat-meta">
            <span class="cat-count" style={`--cat: ${categoria.color}`}>
                {filtered.length} {filtered.length === 1 ? "obra" : "obras"}
            </span>
            <a href="/poesias" class="back-link">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <polyline points="15,18 9,12 15,6"></polyline>
                </svg>
                Toda la colección
            </a>
        </div>
    </div>

    {filtered.length > 0 ? (
        <section class="poems-section">
            <div class="poems-grid">
                {filtered.map((poesia) => <PoesiaCard poesia={poesia} />)}
            </div>
        </section>
    ) : (
        <section class="empty-section">
            <div class="empty-card">
                <p class="empty-icon" aria-hidden="true">📝</p>
                <h2>Aún no hay obras en esta categoría</h2>
                <p>Esta categoría aguarda sus primeros versos.</p>
                <a href="/poesias" class="explore-btn">Explorar toda la colección</a>
            </div>
        </section>
    )}
</Layout>

<style>
    /* ── Hero ── */
    .category-hero {
        text-align: center;
        padding: 3rem 0 3.5rem;
        margin-bottom: 3rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
        background: radial-gradient(
            ellipse at center top,
            color-mix(in srgb, var(--cat) 10%, transparent) 0%,
            transparent 65%
        );
    }

    .cat-icon {
        font-size: 2.5rem;
        margin-bottom: 1.25rem;
        display: block;
        filter: drop-shadow(0 0 12px color-mix(in srgb, var(--cat) 50%, transparent));
    }

    .cat-title {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(2rem, 5vw, 3rem);
        font-weight: 700;
        color: #f4f1de;
        margin-bottom: 1rem;
        line-height: 1.15;
    }

    .cat-desc {
        font-size: 1.05rem;
        color: #a8a5a2;
        font-style: italic;
        line-height: 1.65;
        max-width: 540px;
        margin: 0 auto 2rem;
    }

    .cat-meta {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .cat-count {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--cat);
        background: color-mix(in srgb, var(--cat) 12%, transparent);
        border: 1px solid color-mix(in srgb, var(--cat) 25%, transparent);
        padding: 0.45rem 1.1rem;
        border-radius: 20px;
    }

    .back-link {
        color: #81b29a;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.9rem;
        transition: color 0.2s ease;
    }

    .back-link:hover { color: #9cc5a1; }

    /* ── Poems grid ── */
    .poems-section { margin-bottom: 3rem; }

    .poems-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1.25rem;
    }

    /* ── Empty state ── */
    .empty-section {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 40vh;
        padding: 3rem 1rem;
    }

    .empty-card {
        text-align: center;
        max-width: 420px;
        background: rgba(255, 255, 255, 0.025);
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 16px;
        padding: 2.5rem 2rem;
    }

    .empty-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
        opacity: 0.65;
    }

    .empty-card h2 {
        font-family: "Cormorant Garamond", serif;
        font-size: 1.5rem;
        color: #f4f1de;
        margin-bottom: 0.75rem;
    }

    .empty-card p {
        color: #a8a5a2;
        font-style: italic;
        margin-bottom: 1.75rem;
        line-height: 1.6;
    }

    .explore-btn {
        display: inline-flex;
        align-items: center;
        background: linear-gradient(135deg, #81b29a, #6a9c7a);
        color: #fff;
        text-decoration: none;
        padding: 0.85rem 1.75rem;
        border-radius: 25px;
        font-weight: 500;
        font-size: 0.95rem;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
        box-shadow: 0 4px 14px rgba(129, 178, 154, 0.28);
    }

    .explore-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 22px rgba(129, 178, 154, 0.38);
    }

    /* ── Mobile ── */
    @media (max-width: 768px) {
        .category-hero { padding: 2.5rem 0 3rem; }
        .poems-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 480px) {
        .category-hero { padding: 2rem 0 2.5rem; }
        .cat-meta { flex-direction: column; gap: 0.75rem; }
    }
</style>
