---
import Layout from "../../Layouts/Layout.astro";
import { getCollection } from "astro:content";
import { getCategoryBySlug } from "../../data/categories";

export async function getStaticPaths() {
    const poesias = await getCollection("poesias");
    return poesias.map((poesia) => ({
        params: { titulo: poesia.slug },
        props: { poesia },
    }));
}

const { poesia } = Astro.props;
const { Content } = await poesia.render();

const all = await getCollection("poesias");
const sorted = all.sort((a, b) => a.data.index - b.data.index);
const idx = sorted.findIndex((p) => p.slug === poesia.slug);
const prev = idx > 0 ? sorted[idx - 1] : null;
const next = idx < sorted.length - 1 ? sorted[idx + 1] : null;

// Mood from primary category
const moodMap: Record<string, string> = {
    amor: "romantic",
    melancolia: "melancholic",
    lucha: "intense",
    "salud-mental": "intense",
    reflexion: "dreamy",
    sociedad: "contemplative",
    existencial: "contemplative",
    religion: "contemplative",
};
const cats = poesia.data.categorias || [];
const mood = cats.map((c: string) => moodMap[c]).find(Boolean) ?? "contemplative";

const categories = cats
    .map((slug: string) => getCategoryBySlug(slug))
    .filter(Boolean);

// Generate a plain text excerpt for SEO
const excerpt = poesia.body
    ? poesia.body.split(/\n\s*\n/).filter(Boolean)[0].replace(/\n/g, ' ').substring(0, 150).trim() + "..."
    : `Poesía "${poesia.data.titulo}" en LiraLatente.`;
---

<Layout title={poesia.data.titulo} description={excerpt} type="article">
    <article class={`poem-article mood-${mood}`}>

        <!-- Breadcrumb + back -->
        <nav class="poem-breadcrumb" aria-label="Navegación de regreso">
            <a href="/poesias" class="back-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <polyline points="15,18 9,12 15,6"></polyline>
                </svg>
                Colección
            </a>
            <span class="breadcrumb-sep" aria-hidden="true">/</span>
            <span class="breadcrumb-current">{poesia.data.titulo}</span>
        </nav>

        <!-- Header -->
        <header class="poem-header">
            <div class="poem-meta-row">
                <span class="poem-number">Obra #{poesia.data.index}</span>
                {poesia.data.last && (
                    <span class="latest-badge">Última Creación</span>
                )}
            </div>
            <h1 class="poem-title">{poesia.data.titulo}</h1>

            {categories.length > 0 && (
                <div class="poem-cats" aria-label="Categorías">
                    {categories.map((cat) => (
                        <a
                            href={`/categoria/${cat.slug}`}
                            class="cat-tag"
                            style={`--cat-color: ${cat.color}`}>
                            {cat.icon && <span aria-hidden="true">{cat.icon}</span>}
                            {cat.name}
                        </a>
                    ))}
                </div>
            )}
        </header>

        <!-- Poem body -->
        <div class="poem-body">
            <div class="poem-text">
                <Content />
            </div>
        </div>

        <!-- Keyboard hint -->
        <p class="keyboard-hint hide-mobile" aria-hidden="true">
            Usa ← → para navegar entre obras
        </p>

        <!-- Navigation -->
        <footer class="poem-nav">
            {prev ? (
                <a href={`/poesia/${prev.slug}`} class="nav-link prev" title={`Anterior: ${prev.data.titulo}`}>
                    <div class="nav-dir">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <polyline points="15,18 9,12 15,6"></polyline>
                        </svg>
                        <span>Anterior</span>
                    </div>
                    <span class="nav-title">{prev.data.titulo}</span>
                </a>
            ) : (
                <div></div>
            )}

            <a href="/poesias" class="nav-collection" aria-label="Volver a la colección">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <rect x="3" y="3" width="7" height="7" rx="1"></rect>
                    <rect x="14" y="3" width="7" height="7" rx="1"></rect>
                    <rect x="3" y="14" width="7" height="7" rx="1"></rect>
                    <rect x="14" y="14" width="7" height="7" rx="1"></rect>
                </svg>
                <span>Colección</span>
            </a>

            {next ? (
                <a href={`/poesia/${next.slug}`} class="nav-link next" title={`Siguiente: ${next.data.titulo}`}>
                    <div class="nav-dir">
                        <span>Siguiente</span>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <polyline points="9,18 15,12 9,6"></polyline>
                        </svg>
                    </div>
                    <span class="nav-title">{next.data.titulo}</span>
                </a>
            ) : (
                <div></div>
            )}
        </footer>
    </article>
</Layout>

<style>
    /* Mood CSS variables */
    .mood-romantic    { --accent: #e91e63; --accent-bg: rgba(233, 30, 99, 0.06); }
    .mood-melancholic { --accent: #5c6bc0; --accent-bg: rgba(92, 107, 192, 0.06); }
    .mood-intense     { --accent: #ff5722; --accent-bg: rgba(255, 87, 34, 0.06); }
    .mood-dreamy      { --accent: #9c27b0; --accent-bg: rgba(156, 39, 176, 0.06); }
    .mood-contemplative { --accent: #81b29a; --accent-bg: rgba(129, 178, 154, 0.06); }

    .poem-article {
        max-width: 720px;
        margin: 0 auto;
    }

    /* ── Breadcrumb ── */
    .poem-breadcrumb {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 2rem;
        font-size: 0.875rem;
        color: #888;
        flex-wrap: wrap;
    }

    .back-link {
        color: #81b29a;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        transition: color 0.2s ease;
    }

    .back-link:hover { color: #9cc5a1; }

    .breadcrumb-sep { color: #444; }

    .breadcrumb-current {
        color: #c9c5c2;
        overflow: hidden;
        white-space: nowrap;
        text-overflow: ellipsis;
        max-width: 280px;
    }

    /* ── Header ── */
    .poem-header {
        text-align: center;
        margin-bottom: 3rem;
    }

    .poem-meta-row {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        margin-bottom: 1.25rem;
        flex-wrap: wrap;
    }

    .poem-number {
        font-size: 0.82rem;
        color: #666;
        background: rgba(255, 255, 255, 0.04);
        padding: 0.3rem 0.75rem;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.07);
    }

    .latest-badge {
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #fff;
        background: var(--accent);
        padding: 0.3rem 0.8rem;
        border-radius: 12px;
    }

    .poem-title {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(2rem, 6vw, 3.5rem);
        font-weight: 700;
        color: #f4f1de;
        line-height: 1.15;
        margin: 0 0 1.5rem;
        position: relative;
    }

    .poem-title::after {
        content: "";
        display: block;
        width: 60px;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--accent), transparent);
        margin: 1rem auto 0;
    }

    .poem-cats {
        display: flex;
        gap: 0.5rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .cat-tag {
        text-decoration: none;
        font-size: 0.82rem;
        font-weight: 500;
        padding: 0.35rem 0.85rem;
        border-radius: 14px;
        background: color-mix(in srgb, var(--cat-color) 14%, transparent);
        color: var(--cat-color);
        border: 1px solid color-mix(in srgb, var(--cat-color) 28%, transparent);
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        transition: background 0.2s ease;
    }

    .cat-tag:hover {
        background: color-mix(in srgb, var(--cat-color) 22%, transparent);
    }

    /* ── Poem body ── */
    .poem-body {
        background: var(--accent-bg);
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 16px;
        padding: 3rem 3.5rem;
        margin-bottom: 1.5rem;
        position: relative;
        overflow: hidden;
    }

    .poem-body::before {
        content: "";
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--accent), transparent);
    }

    /* The rendered MDX content */
    .poem-text {
        font-family: "Cormorant Garamond", serif;
        font-size: 1.3rem;
        line-height: 1.75;
        color: #e0ddd9;
        text-rendering: optimizeLegibility;
        -webkit-font-smoothing: antialiased;
    }

    .poem-text :global(p) {
        margin: 0 0 1.5rem;
    }

    .poem-text :global(p:last-child) {
        margin-bottom: 0;
    }

    /* Headings in MDX (if any) */
    .poem-text :global(h1),
    .poem-text :global(h2),
    .poem-text :global(h3) {
        font-family: "Cormorant Garamond", serif;
        color: #f4f1de;
        margin: 2rem 0 1rem;
    }

    /* Emphasis in poem */
    .poem-text :global(em) {
        font-style: italic;
        color: #f0edea;
    }

    .poem-text :global(strong) {
        font-weight: 600;
        color: #f4f1de;
    }

    /* ── Keyboard hint ── */
    .keyboard-hint {
        text-align: center;
        font-size: 0.78rem;
        color: #555;
        margin-bottom: 2rem;
        letter-spacing: 0.02em;
    }

    /* ── Navigation ── */
    .poem-nav {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 0.75rem;
        align-items: center;
        margin-top: 1rem;
    }

    .nav-link {
        text-decoration: none;
        color: inherit;
        background: rgba(255, 255, 255, 0.025);
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 12px;
        padding: 1rem 1.25rem;
        transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .nav-link:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(129, 178, 154, 0.25);
        transform: translateY(-2px);
    }

    .nav-link.prev { grid-column: 1; }
    .nav-link.next { grid-column: 3; text-align: right; }

    .nav-dir {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.8rem;
        color: #777;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .nav-link.next .nav-dir { justify-content: flex-end; }

    .nav-title {
        font-family: "Cormorant Garamond", serif;
        font-size: 0.95rem;
        color: #d0cdc9;
        line-height: 1.3;
        display: block;
    }

    .nav-link.next .nav-title { text-align: right; }

    .nav-collection {
        grid-column: 2;
        color: #81b29a;
        text-decoration: none;
        display: inline-flex;
        flex-direction: column;
        align-items: center;
        gap: 0.35rem;
        font-size: 0.8rem;
        padding: 0.75rem 1rem;
        border-radius: 10px;
        background: rgba(129, 178, 154, 0.08);
        border: 1px solid rgba(129, 178, 154, 0.15);
        transition: background 0.2s ease;
        white-space: nowrap;
    }

    .nav-collection:hover {
        background: rgba(129, 178, 154, 0.14);
    }

    /* ── Mobile ── */
    @media (max-width: 768px) {
        .poem-body { padding: 2rem; }
        .poem-nav {
            grid-template-columns: 1fr;
            gap: 0.6rem;
        }
        .nav-link.prev  { grid-column: 1; order: 1; }
        .nav-link.next  { grid-column: 1; order: 2; text-align: left; }
        .nav-link.next .nav-dir  { justify-content: flex-start; }
        .nav-link.next .nav-title { text-align: left; }
        .nav-collection { grid-column: 1; order: 3; flex-direction: row; justify-content: center; }
    }

    @media (max-width: 480px) {
        .poem-body { padding: 1.5rem; }
        .poem-text { font-size: 1.1rem; }
    }
</style>
