---
import Layout from "../Layouts/Layout.astro";
import { getCollection } from "astro:content";
import { getCategoryBySlug } from "../data/categories";

const poesias = await getCollection("poesias");

let featured = poesias.find((p) => p.data.last === true);
if (!featured) {
    featured = poesias.sort((a, b) => b.data.index - a.data.index)[0];
}
if (!featured) throw new Error("No se encontraron obras en la colección");

// Extract first 3 stanzas from raw body for preview
const getPreviewStanzas = (body: string, count = 3) => {
    return body
        .split(/\n\s*\n/)
        .filter((s) => s.trim().length > 0)
        .slice(0, count)
        .map((stanza) => stanza.trim().split("\n").map((l) => l.trim()));
};

const previewStanzas = getPreviewStanzas(featured.body);
const categories = (featured.data.categorias || [])
    .map((slug: string) => getCategoryBySlug(slug))
    .filter(Boolean);
---

<Layout>
    <section class="hero">
        <div class="hero-inner">
            <p class="eyebrow">Una colección íntima de versos</p>
            <h1 class="hero-title">LiraLatente</h1>
            <p class="hero-desc">
                Donde las emociones se transforman en palabras y las palabras encuentran su alma.
            </p>
            <div class="hero-actions">
                <a href="/poesias" class="btn-primary">
                    Explorar Colección
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <polyline points="9,18 15,12 9,6"></polyline>
                    </svg>
                </a>
                <a href="#ultima-obra" class="btn-secondary">Última obra</a>
            </div>
        </div>
    </section>

    <section id="ultima-obra" class="featured">
        <div class="featured-header">
            <span class="section-label">Última Creación</span>
            <h2 class="featured-subtitle">
                La expresión más reciente del alma
            </h2>
        </div>

        <article class="featured-card">
            <header class="featured-card-header">
                <div class="featured-meta">
                    <h3 class="featured-title">{featured.data.titulo}</h3>
                    <span class="featured-num">Obra #{featured.data.index}</span>
                </div>
                {categories.length > 0 && (
                    <div class="featured-cats">
                        {categories.map((cat) => (
                            <a
                                href={`/categoria/${cat.slug}`}
                                class="cat-pill"
                                style={`--cat-color: ${cat.color}`}>
                                {cat.name}
                            </a>
                        ))}
                    </div>
                )}
            </header>

            <div class="poem-preview-wrapper">
                <div class="poem-preview">
                    {previewStanzas.map((stanza, si) => (
                        <p class="preview-stanza">
                            {stanza.map((line, li) => (
                                <>
                                    {line}
                                    {li < stanza.length - 1 && <br />}
                                </>
                            ))}
                        </p>
                    ))}
                </div>
                <div class="preview-fade" aria-hidden="true"></div>
            </div>

            <footer class="featured-card-footer">
                <a href={`/poesia/${featured.slug}`} class="read-link">
                    Leer completa
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <polyline points="9,18 15,12 9,6"></polyline>
                    </svg>
                </a>
            </footer>
        </article>
    </section>
</Layout>

<style>
    /* ── Hero ── */
    .hero {
        text-align: center;
        padding: 5rem 0 6rem;
        background: radial-gradient(ellipse at 50% 60%, rgba(129, 178, 154, 0.08) 0%, transparent 65%);
    }

    .hero-inner {
        max-width: 640px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .eyebrow {
        font-family: "Cormorant Garamond", serif;
        font-style: italic;
        font-size: 1.05rem;
        color: #81b29a;
        margin-bottom: 1rem;
        opacity: 0.85;
    }

    .hero-title {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(3rem, 9vw, 5.5rem);
        font-weight: 700;
        line-height: 1.05;
        margin-bottom: 1.5rem;
        background: linear-gradient(135deg, #f4f1de 0%, #9cc5a1 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero-desc {
        font-size: 1.15rem;
        color: #b8b5b2;
        line-height: 1.65;
        font-style: italic;
        margin-bottom: 2.5rem;
    }

    .hero-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-primary,
    .btn-secondary {
        text-decoration: none;
        padding: 0.85rem 1.75rem;
        border-radius: 40px;
        font-size: 1rem;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
    }

    .btn-primary {
        background: linear-gradient(135deg, #81b29a, #6a9c7a);
        color: #fff;
        box-shadow: 0 4px 16px rgba(129, 178, 154, 0.28);
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(129, 178, 154, 0.38);
    }

    .btn-secondary {
        background: rgba(255, 255, 255, 0.06);
        color: #e8e6e3;
        border: 1px solid rgba(255, 255, 255, 0.15);
    }

    .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.1);
        transform: translateY(-2px);
    }

    /* ── Featured ── */
    .featured {
        margin-bottom: 4rem;
    }

    .featured-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .section-label {
        display: inline-block;
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #81b29a;
        background: rgba(129, 178, 154, 0.1);
        border: 1px solid rgba(129, 178, 154, 0.2);
        padding: 0.3rem 0.9rem;
        border-radius: 20px;
        margin-bottom: 0.75rem;
    }

    .featured-subtitle {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(1.5rem, 3vw, 2rem);
        color: #c9c5c2;
        font-weight: 400;
        font-style: italic;
    }

    .featured-card {
        background: rgba(255, 255, 255, 0.025);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 18px;
        padding: 2.5rem;
        position: relative;
        overflow: hidden;
    }

    .featured-card::before {
        content: "";
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, #81b29a, transparent);
    }

    .featured-card-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 2rem;
        padding-bottom: 1.25rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.07);
    }

    .featured-meta {
        display: flex;
        align-items: baseline;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .featured-title {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(1.5rem, 3vw, 2rem);
        font-weight: 600;
        color: #f4f1de;
        margin: 0;
    }

    .featured-num {
        font-size: 0.85rem;
        color: #666;
        white-space: nowrap;
    }

    .featured-cats {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .cat-pill {
        text-decoration: none;
        font-size: 0.75rem;
        font-weight: 500;
        padding: 0.3rem 0.75rem;
        border-radius: 12px;
        background: color-mix(in srgb, var(--cat-color) 15%, transparent);
        color: var(--cat-color);
        border: 1px solid color-mix(in srgb, var(--cat-color) 30%, transparent);
        transition: background 0.2s ease;
        white-space: nowrap;
    }

    .cat-pill:hover {
        background: color-mix(in srgb, var(--cat-color) 22%, transparent);
    }

    /* ── Poem preview ── */
    .poem-preview-wrapper {
        position: relative;
        overflow: hidden;
        margin-bottom: 1.5rem;
    }

    .poem-preview {
        font-family: "Cormorant Garamond", serif;
        font-size: 1.15rem;
        line-height: 1.9;
        color: #dedad6;
        padding-bottom: 3rem;
    }

    .preview-stanza {
        margin: 0 0 1.5rem;
    }

    .preview-stanza:last-child { margin-bottom: 0; }

    .preview-fade {
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 100px;
        background: linear-gradient(to bottom, transparent, rgba(15, 15, 35, 0.97) 90%);
        pointer-events: none;
    }

    .featured-card-footer {
        padding-top: 1.25rem;
        border-top: 1px solid rgba(255, 255, 255, 0.07);
        text-align: center;
    }

    .read-link {
        color: #81b29a;
        text-decoration: none;
        font-weight: 500;
        font-size: 1rem;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        transition: color 0.2s ease, gap 0.2s ease;
    }

    .read-link:hover {
        color: #9cc5a1;
        gap: 0.65rem;
    }

    /* ── Mobile ── */
    @media (max-width: 768px) {
        .hero { padding: 3.5rem 0 4.5rem; }
        .featured-card { padding: 1.75rem; }
        .featured-card-header { flex-direction: column; }
        .featured-cats { justify-content: flex-start; }
    }

    @media (max-width: 480px) {
        .hero { padding: 2.5rem 0 3.5rem; }
        .hero-actions { flex-direction: column; align-items: center; }
        .btn-primary, .btn-secondary { width: 100%; max-width: 260px; justify-content: center; }
        .featured-card { padding: 1.25rem; }
        .poem-preview { font-size: 1.05rem; }
    }
</style>
