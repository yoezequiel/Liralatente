---
import { getCollection } from "astro:content";
import PoesiaCard from "../components/PoetryCard.astro";
import Layout from "../Layouts/Layout.astro";
import { getCategoriesWithCount } from "../data/categories";

const poesias = await getCollection("poesias");
const sorted = [...poesias].sort((a, b) => b.data.index - a.data.index);

const first = [...poesias].sort((a, b) => a.data.index - b.data.index)[0];
const last  = sorted[0];
const total = poesias.length;

const categoriesWithCount = getCategoriesWithCount(poesias);
---

<Layout title="Colección Completa">
    <!-- Hero -->
    <div class="collection-hero">
        <h1 class="collection-title">Colección Completa</h1>
        <p class="collection-desc">
            {total} composiciones que exploran los rincones más profundos del alma humana
        </p>

        <div class="stats-row">
            <div class="stat">
                <span class="stat-num">{total}</span>
                <span class="stat-lbl">Obras</span>
            </div>
            <div class="stat">
                <span class="stat-num">{categoriesWithCount.length}</span>
                <span class="stat-lbl">Temas</span>
            </div>
            <div class="stat text-stat">
                <span class="stat-lbl">Primera</span>
                <span class="stat-text">"{first.data.titulo}"</span>
            </div>
            <div class="stat text-stat">
                <span class="stat-lbl">Última</span>
                <span class="stat-text">"{last.data.titulo}"</span>
            </div>
        </div>
    </div>

    <!-- Categories -->
    <section class="themes-section">
        <h2 class="section-title">Explorar por Temas</h2>

        <div class="themes-grid">
            {categoriesWithCount.map((cat) => (
                <a
                    href={`/categoria/${cat.slug}`}
                    class="theme-card"
                    style={`--theme-color: ${cat.color}`}>
                    <div class="theme-icon-wrap">
                        <span class="theme-icon" aria-hidden="true">{cat.icon}</span>
                    </div>
                    <div class="theme-info">
                        <h3 class="theme-name">{cat.name}</h3>
                        <span class="theme-count">{cat.count} {cat.count === 1 ? "obra" : "obras"}</span>
                    </div>
                    <svg class="theme-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <polyline points="9,18 15,12 9,6"></polyline>
                    </svg>
                </a>
            ))}
        </div>
    </section>

    <!-- All poems -->
    <section class="poems-section">
        <div class="section-header">
            <h2 class="section-title">Todas las obras</h2>
            <p class="section-sub">Ordenadas de la más reciente a la primera</p>
        </div>

        <div class="poems-grid">
            {sorted.map((poesia) => <PoesiaCard poesia={poesia} />)}
        </div>
    </section>
</Layout>

<style>
    /* ── Hero ── */
    .collection-hero {
        text-align: center;
        padding: 2.5rem 0 3.5rem;
        margin-bottom: 3.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }

    .collection-title {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(2.2rem, 6vw, 3.5rem);
        font-weight: 700;
        color: #f4f1de;
        line-height: 1.15;
        margin-bottom: 1rem;
    }

    .collection-desc {
        font-size: 1.1rem;
        color: #a8a5a2;
        font-style: italic;
        line-height: 1.6;
        max-width: 560px;
        margin: 0 auto 2.5rem;
    }

    .stats-row {
        display: flex;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .stat {
        background: rgba(255, 255, 255, 0.025);
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 12px;
        padding: 1rem 1.5rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.25rem;
        min-width: 100px;
        transition: background 0.2s ease, border-color 0.2s ease;
    }

    .stat:hover {
        background: rgba(255, 255, 255, 0.04);
        border-color: rgba(129, 178, 154, 0.2);
    }

    .stat-num {
        font-size: 2rem;
        font-weight: 700;
        color: #81b29a;
        line-height: 1;
    }

    .stat-lbl {
        font-size: 0.75rem;
        color: #777;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.07em;
    }

    .stat.text-stat { min-width: 160px; }

    .stat-text {
        font-style: italic;
        color: #c9c5c2;
        font-size: 0.9rem;
        line-height: 1.3;
        text-align: center;
    }

    /* ── Themes ── */
    .themes-section {
        margin-bottom: 4rem;
    }

    .section-title {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(1.5rem, 3vw, 2rem);
        color: #f4f1de;
        margin-bottom: 1.5rem;
        font-weight: 600;
    }

    .themes-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
        gap: 0.75rem;
    }

    .theme-card {
        background: rgba(255, 255, 255, 0.025);
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 12px;
        padding: 1rem 1.25rem;
        text-decoration: none;
        color: inherit;
        display: flex;
        align-items: center;
        gap: 0.85rem;
        transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
        position: relative;
        overflow: hidden;
    }

    .theme-card::before {
        content: "";
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: 3px;
        background: var(--theme-color);
        opacity: 0;
        transition: opacity 0.2s ease;
    }

    .theme-card:hover {
        background: rgba(255, 255, 255, 0.045);
        border-color: color-mix(in srgb, var(--theme-color) 35%, transparent);
        transform: translateX(3px);
    }

    .theme-card:hover::before { opacity: 1; }

    .theme-icon-wrap {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        background: color-mix(in srgb, var(--theme-color) 15%, transparent);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 1.1rem;
    }

    .theme-info {
        flex: 1;
        min-width: 0;
    }

    .theme-name {
        font-family: "Cormorant Garamond", serif;
        font-size: 0.95rem;
        color: #f4f1de;
        font-weight: 600;
        margin: 0 0 0.15rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .theme-count {
        font-size: 0.78rem;
        color: #777;
        font-weight: 500;
    }

    .theme-arrow {
        color: #555;
        flex-shrink: 0;
        transition: color 0.2s ease, transform 0.2s ease;
    }

    .theme-card:hover .theme-arrow {
        color: var(--theme-color);
        transform: translateX(2px);
    }

    /* ── All poems ── */
    .poems-section { margin-bottom: 2rem; }

    .section-header { margin-bottom: 2rem; }

    .section-sub {
        color: #777;
        font-style: italic;
        font-size: 0.95rem;
        margin-top: 0.25rem;
    }

    .poems-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 1.25rem;
    }

    /* ── Mobile ── */
    @media (max-width: 768px) {
        .stats-row { gap: 0.75rem; }
        .stat { padding: 0.85rem 1rem; min-width: 85px; }
        .stat.text-stat { min-width: 140px; }
        .themes-grid { grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); }
        .poems-grid { grid-template-columns: 1fr; }
    }

    @media (max-width: 480px) {
        .collection-hero { padding: 1.5rem 0 2.5rem; }
        .stats-row { gap: 0.5rem; }
        .stat { padding: 0.75rem 0.85rem; }
        .stat-num { font-size: 1.6rem; }
        .themes-grid { grid-template-columns: 1fr 1fr; gap: 0.5rem; }
    }
</style>
