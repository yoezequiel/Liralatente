---
const { title } = Astro.props;
import Nav from "../components/Nav.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content="LiraLatente - Una colección íntima de obras que exploran el alma humana, el amor, la melancolía y la profundidad de las emociones" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
        <meta name="theme-color" content="#0f0f23" />
        <meta name="apple-mobile-web-app-capable" content="yes" />
        <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
        <title>{title ? `${title} • LiraLatente` : "LiraLatente - Obras del Alma"}</title>
        <link rel="shortcut icon" href="../img/icon.png" type="image/x-icon" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600&display=swap" rel="stylesheet" />
    </head>
    <body>
        <div class="grain-overlay"></div>

        <header class="site-header">
            <Nav />
        </header>

        <main>
            <slot />
        </main>

        <footer class="site-footer">
            <div class="footer-content">
                <p class="copyright">&copy; 2026 LiraLatente</p>
                <p class="tagline">Donde las palabras encuentran su alma</p>
            </div>
        </footer>
    </body>
    <script src="/src/scripts/interactions.js"></script>
    <style>
        *, *::before, *::after {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
            height: 100%;
            overflow-x: hidden;
            background-color: #0f0f23;
        }

        body {
            background: linear-gradient(135deg, #0f0f23 0%, #1a1a2e 50%, #16213e 100%);
            background-attachment: fixed;
            font-family: "Cormorant Garamond", "Georgia", serif;
            color: #e8e6e3;
            line-height: 1.7;
            min-height: 100dvh;
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
        }

        .grain-overlay {
            position: fixed;
            inset: 0;
            opacity: 0.025;
            background-image:
                radial-gradient(circle at 25% 25%, #fff 1px, transparent 1px),
                radial-gradient(circle at 75% 75%, #fff 1px, transparent 1px);
            background-size: 12px 12px;
            background-position: 0 0, 6px 6px;
            pointer-events: none;
            z-index: 0;
        }

        .site-header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(13, 13, 30, 0.85);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.07);
        }

        main {
            flex: 1;
            position: relative;
            z-index: 1;
            max-width: 900px;
            width: 100%;
            margin: 0 auto;
            padding: 2.5rem 1.5rem 4rem;
        }

        .site-footer {
            position: relative;
            z-index: 1;
            background: rgba(10, 10, 26, 0.7);
            backdrop-filter: blur(10px);
            border-top: 1px solid rgba(255, 255, 255, 0.07);
            padding: 1.5rem 0;
        }

        .footer-content {
            max-width: 900px;
            margin: 0 auto;
            text-align: center;
            padding: 0 1.5rem;
        }

        .copyright {
            font-size: 0.85rem;
            color: #888;
        }

        .tagline {
            font-style: italic;
            font-size: 0.8rem;
            color: #81b29a;
            opacity: 0.7;
            margin-top: 0.25rem;
        }

        .page-title {
            font-family: "Cormorant Garamond", serif;
            font-size: clamp(2.2rem, 5vw, 3.5rem);
            font-weight: 600;
            color: #f4f1de;
            text-align: center;
            margin-bottom: 3rem;
            position: relative;
            line-height: 1.2;
        }

        .page-title::after {
            content: "";
            position: absolute;
            bottom: -1rem;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 2px;
            background: linear-gradient(90deg, transparent, #81b29a, transparent);
        }

        @media (max-width: 768px) {
            main { padding: 2rem 1rem 3rem; }
        }

        @media (max-width: 480px) {
            main { padding: 1.5rem 0.75rem 2.5rem; }
        }

        @supports not (min-height: 100dvh) {
            body { min-height: 100vh; }
        }
    </style>
</html>
