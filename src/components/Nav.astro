---
const { pathname } = Astro.url;
const isCollection =
    pathname.startsWith("/poesias") ||
    pathname.startsWith("/poesia/") ||
    pathname.startsWith("/categoria/");
---

<nav class="nav" aria-label="Navegación principal">
    <div class="nav-container">
        <a href="/" class="logo" aria-label="LiraLatente - Inicio">
            <span class="logo-text">Lira</span><span class="logo-accent">Latente</span>
        </a>
        <ul class="nav-links" role="list">
            <li>
                <a
                    href="/"
                    class={`nav-link ${pathname === "/" ? "active" : ""}`}
                    aria-current={pathname === "/" ? "page" : undefined}>
                    Inicio
                </a>
            </li>
            <li>
                <a
                    href="/poesias"
                    class={`nav-link ${isCollection ? "active" : ""}`}
                    aria-current={isCollection ? "page" : undefined}>
                    Colección
                </a>
            </li>
        </ul>
    </div>
</nav>

<style>
    .nav {
        width: 100%;
    }

    .nav-container {
        max-width: 900px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.85rem 1.5rem;
        gap: 1rem;
    }

    .logo {
        text-decoration: none;
        font-family: "Cormorant Garamond", serif;
        font-size: 1.6rem;
        font-weight: 600;
        flex-shrink: 0;
        transition: opacity 0.2s ease;
    }

    .logo:hover { opacity: 0.8; }

    .logo-text   { color: #f4f1de; }
    .logo-accent { color: #81b29a; font-style: italic; }

    .nav-links {
        display: flex;
        gap: 0.5rem;
        list-style: none;
        margin: 0;
        padding: 0;
        flex-shrink: 0;
    }

    .nav-link {
        text-decoration: none;
        color: #c9c5c2;
        font-size: 1rem;
        font-weight: 400;
        padding: 0.45rem 1rem;
        border-radius: 20px;
        border: 1px solid transparent;
        transition: color 0.2s ease, background 0.2s ease, border-color 0.2s ease;
        display: block;
        white-space: nowrap;
    }

    .nav-link:hover {
        color: #f4f1de;
        background: rgba(129, 178, 154, 0.12);
        border-color: rgba(129, 178, 154, 0.25);
    }

    .nav-link.active {
        color: #f4f1de;
        background: rgba(129, 178, 154, 0.18);
        border-color: rgba(129, 178, 154, 0.35);
    }

    @media (max-width: 480px) {
        .nav-container { padding: 0.75rem 1rem; }
        .logo          { font-size: 1.35rem; }
        .nav-link      { font-size: 0.9rem; padding: 0.4rem 0.75rem; }
    }
</style>
